              </table-calc>
            </column-instance>
            <column caption='Total Revenue' datatype='real' name='[total_revenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1098187251060749]' derivation='User' name='[usr:Calculation_1098187251060749:nk:2]' pivot='key' type='nominal'>
              <table-calc ordering-type='Columns' />
            </column-instance>
            <column-instance column='[Calculation_1098187260973071]' derivation='User' name='[usr:Calculation_1098187260973071:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' />
              <table-calc field='[federated.04fw5p90hdv65j1etj24t0p75c58].[Calculation_1098187262136336]' ordering-type='Columns' />
