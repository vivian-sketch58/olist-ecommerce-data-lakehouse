          <zone h='15696' id='23' param='horz' type-v2='layout-flow' w='98968' x='516' y='83353'>
            <zone forceUpdate='true' h='15696' id='24' type-v2='text' w='98968' x='516' y='83353'>
              <formatted-text>
                <run bold='true' fontcolor='#000000' fontsize='12'>Note:</run>
                <run fontcolor='#000000' fontsize='12'> With a Live connection, every time you filter or interact with the dashboard, Tableau sends a SQL query to BigQuery. This is great for real-time data but will incur BigQuery query costs based on the amount of data scanned.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
