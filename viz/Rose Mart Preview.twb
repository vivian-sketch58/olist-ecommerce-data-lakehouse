      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='950' minheight='950' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='44' type-v2='layout-basic' w='100000' x='0' y='0'>
              <zone h='98098' id='43' param='vert' type-v2='layout-flow' w='98968' x='516' y='951'>
                <zone fixed-size='1314' forceUpdate='true' h='12723' id='17' type-v2='text' w='85290' x='516' y='951'>
                  <formatted-text>
                    <run bold='true' fontcolor='#4e79a7' fontsize='20'>Live</run>
                    <run fontcolor='#4e79a7' fontsize='20'> connection Blue Rose Marts with full BigQuery data</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#4e79a7' fontname='Arial,sans-serif' fontsize='10'>Switch from the sample data to full BigQuery project.</run>
                    <run>Æ&#10;&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='93' h='12723' id='18' is-fixed='true' is-scaled='1' param='//wsl.localhost/Ubuntu/home/vivian/_Project_M2_DataEngeering/BlueRose.png' type-v2='bitmap' w='13678' x='85806' y='951'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='461' forceUpdate='true' h='14744' id='19' type-v2='text' w='61226' x='516' y='13674'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontsize='14'>Step 1: Add the Connection</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontsize='12'>     •  In Tableau Desktop, go to the </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Data Source</run>
                    <run fontcolor='#000000' fontsize='12'> tab or click </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Data &gt; New Data Source</run>
                    <run fontcolor='#000000' fontsize='12'>.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontsize='12'>     •  Under &quot;To a Server,&quot; select </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Google BigQuery</run>
                    <run fontcolor='#000000' fontsize='12'>.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontsize='12'>     •  Sign in using the Google account that has access to your BigQuery project.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='205' h='26635' id='20' is-fixed='true' is-scaled='1' param='//wsl.localhost/Ubuntu/home/vivian/_Project_M2_DataEngeering/Live Connection 1.png' type-v2='bitmap' w='37742' x='61742' y='13674'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='226' forceUpdate='true' h='21522' id='21' type-v2='text' w='61226' x='516' y='40309'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Step 2: Select Full Data</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontsize='12'>  •  Choose  </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Billing Project</run>
                    <run fontcolor='#000000' fontsize='12'>, </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Project</run>
                    <run fontcolor='#000000' fontsize='12'>, and the </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Dataset</run>
                    <run fontcolor='#000000' fontsize='12'> where mart layer  tables and dim_date table are stored.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontsize='12'>  •  Drag these tables (e.g., Olist dim_date and marts_sales_summary tables) onto the canvas.</run>
                    <run>Æ&#10;&#10;&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' forceUpdate='true' h='43044' id='39' is-fixed='true' is-scaled='1' param='//wsl.localhost/Ubuntu/home/vivian/_Project_M2_DataEngeering/Live Connection 5.png' type-v2='bitmap' w='37742' x='61742' y='40309'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='141' forceUpdate='true' h='17717' id='22' type-v2='text' w='61226' x='516' y='61831'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Step 3: Toggle &quot;Live&quot;</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontsize='12'>  •  In the top-right corner of the Data Source page, ensure </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Live</run>
                    <run fontcolor='#000000' fontsize='12'> is selected (instead of </run>
                    <run bold='true' fontcolor='#000000' fontsize='12'>Extract</run>
