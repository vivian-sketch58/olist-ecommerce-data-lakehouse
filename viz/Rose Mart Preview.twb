      <aliases enabled='yes' />
      <column caption='order_date_key' datatype='integer' name='[Calculation_1098187217629186]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Converts 2020-12-16 into 20201216&#13;&#10;INT(STR(YEAR([order_date])) + &#13;&#10;    IF MONTH([order_date]) &lt; 10 THEN &quot;0&quot; ELSE &quot;&quot; END + STR(MONTH([order_date])) + &#13;&#10;    IF DAY([order_date]) &lt; 10 THEN &quot;0&quot; ELSE &quot;&quot; END + STR(DAY([order_date])))' />
      </column>
      <column caption='Year_abc' datatype='string' name='[Calculation_1098187242323975]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([year])' />
      </column>
      <column caption='last_sales_mth' datatype='boolean' name='[Calculation_1098187251060749]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// This checks if the date has any sales data attached to it&#13;&#10;LAST() = 0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='MoM%_pos' datatype='real' name='[Calculation_1098187260973071]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1098187262136336] &gt; 0 THEN [Calculation_1098187262136336] END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='MoM%' datatype='real' name='[Calculation_1098187262136336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([total_revenue])) - LOOKUP(ZN(SUM([total_revenue])), -1)) / ABS(LOOKUP(ZN(SUM([total_revenue])), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='MoM_neg' datatype='real' name='[Calculation_1098187262513169]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1098187262136336] &lt;= 0 THEN [Calculation_1098187262136336] END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg_orders_per_mth' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_1098187289452563]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ AVG({ FIXED DATETRUNC(&apos;month&apos;, [order_date]) : COUNT([__tableau_internal_object_id__].[marts_sales_summary.csv_62B3FC69A7EB40B387C7C4112FE43C56]) }) }' />
      </column>
      <column caption='Avg_orders_per_day' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_1098187290271764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ AVG({ FIXED DATETRUNC(&apos;day&apos;, [order_date]) : COUNT([__tableau_internal_object_id__].[marts_sales_summary.csv_62B3FC69A7EB40B387C7C4112FE43C56]) }) }' />
      </column>
      <column caption='Revenue YoY%' datatype='real' default-format='p0.0%' name='[Calculation_1098187294666773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1098187296120855]) - SUM([Calculation_1098187295821846])) / SUM([Calculation_1098187295821846])' />
      </column>
      <column caption='Revenue LY (2017)' datatype='real' name='[Calculation_1098187295821846]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [order_date] : SUM(IF YEAR([order_date]) = 2017 THEN [total_revenue] ELSE 0 END) }' />
      </column>
      <column caption='Revenue CY (2018)' datatype='real' name='[Calculation_1098187296120855]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [order_date] : SUM(IF YEAR([order_date]) = 2018 THEN [total_revenue] ELSE 0 END) }' />
      </column>
