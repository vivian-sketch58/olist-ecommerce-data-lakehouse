    <dashboard enable-sort-zone-taborder='true' name='Why marts'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='32282' id='26' is-fixed='true' type-v2='layout-basic' w='35502' x='63978' y='951'>
            <zone h='32282' id='27' param='horz' type-v2='layout-flow' w='35502' x='63978' y='951'>
              <zone h='32282' id='25' is-centered='0' param='//wsl.localhost/Ubuntu/home/vivian/_Project_M2_DataEngeering/Rose.png' type-v2='bitmap' w='35502' x='63978' y='951'>
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='4' />
                </zone-style>
              </zone>
            </zone>
          </zone>
          <zone h='63972' id='28' param='vert' type-v2='layout-flow' w='63458' x='520' y='951'>
            <zone fixed-size='94' forceUpdate='true' h='12128' id='12' is-fixed='true' type-v2='text' w='63458' x='520' y='951'>
              <formatted-text>
                <run bold='true' fontcolor='#4e79a7' fontsize='20'>Why is Rose Data Marts?</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone fixed-size='470' forceUpdate='true' h='51844' id='15' is-fixed='true' type-v2='text' w='63458' x='520' y='13079'>
              <formatted-text>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>&apos;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>Centrol of True</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>&apos; Golden Data Lakehouse to Actionable Business Ready - </run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>Rose Marts</run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>1. The Challenge (The &quot;Before&quot;)</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>    Data Silos:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Raw data is scattered and inconsistent.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>    High Latency:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Complex queries on raw data are slow and expensive.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Metric Drift:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Different teams reporting different &quot;Revenue&quot; numbers.</run>
                <run>Æ&#10;&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>2. Strategic Benefits of Data Marts</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Performance:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Pre-aggregated tables reduce dashboard load times by up to 80%.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Governance:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Fine-grained access control (Role-Based Access) ensures data security.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Consistency:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Shared definitions for KPIs across the entire organization.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
          </zone>
          <zone h='31690' id='8' param='horz' type-v2='layout-flow' w='35502' x='63978' y='33233'>
            <zone forceUpdate='true' h='31690' id='18' type-v2='text' w='35502' x='63978' y='33233'>
              <formatted-text>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>3. Key Outcomes  - Rose Marts</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Cost Efficiency:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Lower compute costs by querying smaller, modeled datasets.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Self-Service BI:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Analysts can build reports without needing complex SQL joins.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>   Reliability:</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'> Automated testing in the transformation layer (e.g., dbt tests) ensures data quality.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
          </zone>
          <zone h='34126' id='29' param='horz' type-v2='layout-flow' w='98960' x='520' y='64923'>
            <zone fixed-size='255' h='34126' id='32' is-centered='0' is-fixed='true' is-scaled='1' param='//wsl.localhost/Ubuntu/home/vivian/_Project_M2_DataEngeering/GoldenDWH.png' type-v2='bitmap' w='17100' x='520' y='64923'>
