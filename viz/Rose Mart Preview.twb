    <dashboard enable-sort-zone-taborder='true' name='sales_summ'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='9259' id='3' param='horz' type-v2='layout-flow' w='98960' x='520' y='951'>
            <zone forceUpdate='true' h='9259' id='16' type-v2='text' w='80885' x='520' y='951'>
              <formatted-text>
                <run bold='true' fontcolor='#4e79a7' fontname='Benton Sans Book' fontsize='20'>Executive Sales Overview</run>
                <run fontcolor='#4e79a7' fontname='Benton Sans Book' fontsize='20'>Æ </run>
                <run fontcolor='#4e79a7' fontname='Benton Sans Book' fontsize='15'>(Jan 2017~ Aug 2018)</run>
                <run>Æ&#10;</run>
                <run fontcolor='#4e79a7' fontname='Tableau Light' fontsize='12'>Note: Results based on sample data of 5000.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
