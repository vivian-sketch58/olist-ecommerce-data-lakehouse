            <column-instance column='[Calculation_1098187242323975]' derivation='None' name='[none:Calculation_1098187242323975:nk]' pivot='key' type='nominal' />
            <column-instance column='[total_revenue]' derivation='Sum' name='[pcdf:sum:total_revenue:qk]' pivot='key' type='quantitative'>
              <table-calc diff-options='Relative' ordering-type='Columns' type='PctDiff'>
                <address>
                  <value>-1</value>
